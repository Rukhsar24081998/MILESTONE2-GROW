# Copy to .env and fill in values. Never commit .env.

# --- LLM (Groq - Phase 3+) ---
# Get your API key from https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_api_key_here

# Recommended Groq models:
# - llama-3.1-8b-instant (fast, default)
# - mixtral-8x7b-32768 (larger context)
# - llama-3.3-70b-versatile (higher accuracy)
LLM_MODEL=llama-3.1-8b-instant

# LLM parameters (low temperature for factual answers)
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=300

# --- Embeddings (Phase 1+) ---
# For local offline embedding, use BAAI/bge-small-en-v1.5
# For OpenAI api-based embedding, use text-embedding-3-small (requires OpenAI API key)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- API (Phase 5+) ---
API_HOST=0.0.0.0
API_PORT=8000

# --- UI (Phase 4+) ---
VITE_API_BASE_URL=http://localhost:8000
